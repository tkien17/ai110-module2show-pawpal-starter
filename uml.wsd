@startuml PawPal UML Design

class Pet {
  +name: str
  +species: str
  +age: int
  +special_needs: list[str]
}

class Owner {
  +name: str
  +available_hours_per_day: int
  +preferences: dict
  +pet: Pet
  +tasks: list[Task]
  +add_task(task: Task)
  +edit_task(task: Task)
}

class Task {
  +name: str
  +duration_minutes: int
  +priority: str  // high, medium, low
  +category: str  // feeding, walking, grooming, etc.
  +frequency: str  // daily, weekly, etc.
}

class ScheduledTask {
  +task: Task
  +start_time: str  // e.g., "08:00"
  +end_time: str
}

class Plan {
  +scheduled_tasks: list[ScheduledTask]
  +total_time: int
  +display_plan() -> str
}

class Scheduler {
  +generate_plan(owner: Owner) -> Plan
  -prioritize_tasks(tasks: list[Task]) -> list[Task]
  -schedule_tasks(tasks: list[Task], available_time: int) -> list[ScheduledTask]
}

' Relationships
Owner --> Pet : owns 1
Owner --> Task : manages *
Task --> ScheduledTask : becomes
Scheduler --> Plan : generates 1
Plan --> ScheduledTask   : contains *

@enduml
